# Firebase configuration. Copy this file to .env.local and fill in your
# Firebase project values from Firebase Console > Project Settings > Your apps.
#
# These values end up in the client bundle, so they are not "secret" in the
# usual sense — protect your data with Firestore security rules instead. See
# README.md for the recommended rules.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
